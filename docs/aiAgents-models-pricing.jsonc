      { "modelId": "grok-4.20", "active": false, // ZWERYFIKUJ
        "pricing": { "currency": "USD", "inputPerMTok": 2, "cacheReadPerMTok": 0.2, "outputPerMTok": 6 } },
      { "modelId": "grok-4.3", "active": false, // ZWERYFIKUJ
        "pricing": { "currency": "USD", "inputPerMTok": 1.25, "cacheReadPerMTok": 0.2, "outputPerMTok": 2.5 } },
      { "modelId": "grok-build-0.1", "active": false, // ZWERYFIKUJ
        "pricing": { "currency": "USD", "inputPerMTok": 1, "cacheReadPerMTok": 0.2, "outputPerMTok": 2 } },

      { "modelId": "kimi-k2.5", "active": false, // ZWERYFIKUJ
        "pricing": { "currency": "USD", "inputPerMTok": 0.6, "cacheReadPerMTok": 0.1, "outputPerMTok": 3 } }
    ]
  },

  // Claude CLI nie ma komendy listującej modele nieinteraktywnie, więc nie
  // ma sensu "listModelsArgs" — zostaw tę listę ręcznie skonfigurowaną.
  {
    "id": "claude-cli",
    "name": "Claude CLI",
    "command": "claude",
    "args": ["{{prompt}}"],
    "enabled": false,
    "allowModels": true,
    "models": ["auto", "sonnet", "opus"],
    "pricing": { "currency": "USD", "inputPerMTok": 3, "outputPerMTok": 15, "cacheReadPerMTok": 0.3 }
  }
]

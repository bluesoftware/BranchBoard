      { "modelId": "gpt-5.4-nano", "active": false, // ZWERYFIKUJ
        "pricing": { "currency": "USD", "inputPerMTok": 0.2, "cacheReadPerMTok": 0.02, "outputPerMTok": 1.25 } },
      { "modelId": "gpt-5.5", "active": false, // ZWERYFIKUJ
